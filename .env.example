# Local Postgres. Matches docker-compose.yml.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/swedenmark

# Optional. Set to use the real Anthropic adapter; otherwise the in-process
# fixture adapter is used (which is what the integration test relies on).
# ANTHROPIC_API_KEY=

# Optional. Override the default LLM adapter ("fixture" | "anthropic").
# LLM_ADAPTER=fixture
